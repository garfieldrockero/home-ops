{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "description": "Detect container images in Kubernetes manifests",
      "customType": "regex",
      "fileMatch": ["cluster/(?!base/flux-system/).+\\.ya?ml$"],
      "matchStrings": [
        "image:\\s+(?<depName>[^:]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Detect images with renovate inline annotations (github-releases)",
      "customType": "regex",
      "fileMatch": ["cluster/.+\\.ya?ml$"],
      "matchStrings": [
        "#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)\\s+datasource=(?<datasource>[^\\s]+)\\n\\s+image:\\s+[^:]+:(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "{{datasource}}"
    },
    {
      "description": "Detect image tags with renovate inline annotations in Helm values",
      "customType": "regex",
      "fileMatch": ["cluster/.+\\.ya?ml$"],
      "matchStrings": [
        "#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)\\s+datasource=(?<datasource>[^\\s]+)\\n\\s+tag:\\s+\"?(?<currentValue>[^@\"\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "{{datasource}}"
    },
    {
      "description": "Detect Helm chart versions in HelmRelease manifests",
      "customType": "regex",
      "fileMatch": ["cluster/.+helm-release\\.ya?ml$"],
      "matchStrings": [
        "chart:\\s+(?<depName>[^\\n]+)\\n\\s+version:\\s+(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
