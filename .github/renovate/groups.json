{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Flux Group",
      "groupName": "Flux",
      "matchPackagePatterns": ["flux", "fluxcd"],
      "matchDatasources": ["docker", "github-tags", "github-releases"],
      "versioning": "semver",
      "ignoreUnstable": true,
      "separateMinorPatch": true
    },
    {
      "description": "MetalLB Group",
      "groupName": "MetalLB",
      "matchPackagePatterns": ["metallb"],
      "matchDatasources": ["helm"],
      "ignoreUnstable": true
    }
  ]
}
