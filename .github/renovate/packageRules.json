{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Loose versioning for non-semver packages",
      "matchDatasources": ["docker"],
      "versioning": "loose"
    },
    {
      "description": "Require manual approval for all updates",
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "automerge": false
    },
    {
      "description": "fireflyiii images use version-X.Y.Z tag format",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["fireflyiii/core", "fireflyiii/data-importer"],
      "versioning": "regex:^version-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "description": "Disable digest and pin updates for manually pinned images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/dgtlmoon/changedetection.io",
        "dgtlmoon/sockpuppetbrowser"
      ],
      "matchUpdateTypes": ["digest", "pin", "pinDigest"],
      "enabled": false
    },
    {
      "description": "Ignore o2cr.ai registry (not accessible by Renovate)",
      "matchPackagePatterns": ["^o2cr\\.ai/"],
      "enabled": false
    },
    {
      "description": "cert-manager: only stable releases, no alpha/beta/RC",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["cert-manager"],
      "allowedVersions": "/^v\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Ollama: only stable CPU releases, no RC or ROCm variants",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ollama/ollama"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    }
  ]
}
